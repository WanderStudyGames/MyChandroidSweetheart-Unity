      "text": "Difficulty feedback:\nDon't introduce mechanics and challenge simultaneously.",
      "type": "text",
      "width": 360,
      "x": -360,
      "y": -3140
    },
    {
      "height": 100,
      "id": "cc07e1adc7094bf4",
      "styleAttributes": {
      },
      "text": "Eliminate noise unrelated to the puzzle's essence.",
      "type": "text",
      "width": 360,
      "x": -360,
      "y": -2980
    },
    {
      "height": 120,
      "id": "6d44d2889babfd48",
      "styleAttributes": {
      },
      "text": "Create windows or clear vantage points for connection requirements.",
      "type": "text",
      "width": 360,
      "x": -360,
      "y": -2860
    },
    {
      "color": "4",
      "height": 60,
      "id": "f6645ae71d2937ad",
      "styleAttributes": {
      },
      "text": "Breathing device intro",
      "type": "text",
      "width": 280,
      "x": -320,
      "y": -3240
    },
    {
      "color": "7",
